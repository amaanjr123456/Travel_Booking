{
  "version": 2,
  "builds": [
    { "src": "backend/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin_booking/admin.html", "use": "@vercel/static" },
    { "src": "Resources/**", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/index.js" },
    { "source": "/admin", "destination": "admin_booking/admin.html" }
  ]
}
